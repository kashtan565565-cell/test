DELIMITER $$

CREATE PROCEDURE payment.sp_financial_report (
    IN p_from DATETIME,                 -- Начало периода (в переданном часовом поясе)
    IN p_to DATETIME,                   -- Конец периода (в переданном часовом поясе)
    IN p_country_id SMALLINT UNSIGNED,  -- Опциональный фильтр по стране
    IN p_type_oper_id SMALLINT UNSIGNED,-- Опциональный фильтр по типу операции
    IN p_tz VARCHAR(50)                 -- Часовой пояс входных дат
)
BEGIN

  DECLARE v_from_utc DATETIME;
  DECLARE v_to_utc   DATETIME;

  -- ВАЛИДАЦИЯ ПАРАМЕТРОВ

  -- Проверяем корректность диапазона
  IF p_from IS NULL OR p_to IS NULL OR p_from > p_to THEN
      SIGNAL SQLSTATE '45000'
      SET MESSAGE_TEXT = 'Некорректный период дат';
  END IF;

  -- Если таймзона не передана — считаем, что вход в UTC
  IF p_tz IS NULL OR p_tz = '' THEN
      SET p_tz = 'UTC';
  END IF;

  -- Если передана только дата без времени,
  -- считаем период до конца дня (полуоткрытый интервал)
  IF TIME(p_to) = '00:00:00' THEN
      SET p_to = DATE_ADD(p_to, INTERVAL 1 DAY);
  END IF;

  /*
  ============================================================
  Входные даты конвертируем в UTC,
  чтобы корректно фильтровать user_operations.
  ============================================================
  */

  SET v_from_utc = CONVERT_TZ(p_from, p_tz, 'UTC');
  SET v_to_utc   = CONVERT_TZ(p_to,   p_tz, 'UTC');

  /*
  ============================================================
  Используем dynamic SQL, чтобы:
  - не использовать OR
  - сохранить возможность использования индексов
  ============================================================
  */

  SET @sql = CONCAT(
    'SELECT
        CASE WHEN GROUPING(c.name_country)=1 THEN ''TOTAL:'' ELSE c.name_country END AS country_name,
        CASE WHEN GROUPING(t.name_oper)=1 THEN ''TOTAL:'' ELSE t.name_oper END AS oper_name,
        ROUND(SUM(x.amount_rub),2) AS amount_rub,
        ROUND(SUM(x.amount_comiss_rub),2) AS amount_comiss_rub,
        ROUND(SUM(x.amount_no_comiss_rub),2) AS amount_no_comiss_rub
     FROM (
         SELECT
             u.id_country,
             uo.id_type_oper,

             -- Переводим сумму операции в рубли
             SUM(uo.amount_oper / cur.base_rate) AS amount_rub,

             -- Рассчитываем комиссию в рублях
             SUM((uo.amount_oper / cur.base_rate) * t.commission / 100) AS amount_comiss_rub,

             -- Сумма без комиссии
             SUM(uo.amount_oper / cur.base_rate)
               - SUM((uo.amount_oper / cur.base_rate) * t.commission / 100) AS amount_no_comiss_rub

         FROM payment.user_operations uo
         JOIN payment.users u ON u.id_user = uo.id_user
         JOIN payment.type_opers t ON t.id_type_oper = uo.id_type_oper
         JOIN payment.currencies cur ON cur.id_currency = u.id_currency

         WHERE uo.dt >= ''', v_from_utc, '''
           AND uo.dt <  ''', v_to_utc, ''''
  );

  -- Добавляем фильтры только если они переданы
  IF p_country_id IS NOT NULL THEN
      SET @sql = CONCAT(@sql, ' AND u.id_country = ', p_country_id);
  END IF;

  IF p_type_oper_id IS NOT NULL THEN
      SET @sql = CONCAT(@sql, ' AND uo.id_type_oper = ', p_type_oper_id);
  END IF;

  /*
  ============================================================
  ФИНАЛЬНАЯ АГРЕГАЦИЯ 
  GROUP BY + WITH ROLLUP:
  - итоги по каждой стране
  - общий итог
  ============================================================
  */

  SET @sql = CONCAT(@sql,
        ' GROUP BY u.id_country, uo.id_type_oper
      ) x
      JOIN payment.countries c ON c.id_country = x.id_country
      JOIN payment.type_opers t ON t.id_type_oper = x.id_type_oper
      GROUP BY c.name_country, t.name_oper WITH ROLLUP
      ORDER BY
        GROUPING(c.name_country),
        c.name_country,
        GROUPING(t.name_oper),
        t.name_oper'
    );

  PREPARE stmt FROM @sql;
  EXECUTE stmt;
  DEALLOCATE PREPARE stmt;

END$$
DELIMITER ;

