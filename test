--Процедура ротации
DELIMITER $$

CREATE PROCEDURE payment.sp_rotate_log_partitions()
BEGIN
    DECLARE v_today DATE;
    DECLARE v_keep_from DATE;
    DECLARE v_date DATE;
    DECLARE v_partition_name VARCHAR(20);
    DECLARE v_partitions_to_drop TEXT;
    DECLARE v_exists INT DEFAULT 0;

    /*
    ============================================================
    ОПРЕДЕЛЯЕМ ГРАНИЦЫ ХРАНЕНИЯ
    Храним последние 7 завершённых дней.
    ============================================================
    */

    SET v_today      = CURDATE();
    SET v_keep_from  = DATE_SUB(v_today, INTERVAL 7 DAY);

    /*
    ============================================================
    УДАЛЕНИЕ СТАРЫХ ПАРТИЦИЙ
    Формируем список партиций старше допустимой даты.
    ============================================================
    */

    SELECT GROUP_CONCAT(partition_name ORDER BY partition_name SEPARATOR ',')
    INTO v_partitions_to_drop
    FROM information_schema.PARTITIONS
    WHERE table_schema = 'payment'
      AND table_name = 'log_users'
      AND partition_name IS NOT NULL
      AND partition_name <> 'p_future'
      AND partition_name < CONCAT('p', DATE_FORMAT(v_keep_from, '%Y%m%d'));

    IF v_partitions_to_drop IS NOT NULL THEN

        SET @sql = CONCAT(
            'ALTER TABLE payment.log_users DROP PARTITION ',
            v_partitions_to_drop
        );

        PREPARE stmt FROM @sql;
        EXECUTE stmt;
        DEALLOCATE PREPARE stmt;

    END IF;

    /*
    ============================================================
    ДОБАВЛЕНИЕ ПАРТИЦИЙ НА СЕГОДНЯ И +2 ДНЯ
    Это обеспечивает автoвосстановление после простоя.
    ============================================================
    */

    SET v_date = v_today;

    WHILE v_date <= DATE_ADD(v_today, INTERVAL 2 DAY) DO

        SET v_partition_name = CONCAT('p', DATE_FORMAT(v_date, '%Y%m%d'));

        SELECT COUNT(*)
        INTO v_exists
        FROM information_schema.PARTITIONS
        WHERE table_schema = 'payment'
          AND table_name = 'log_users'
          AND partition_name = v_partition_name;

        IF v_exists = 0 THEN

            
            --"вырезаем" диапазон из future и создаём конкретную дневную партицию
            
            SET @sql = CONCAT(
                'ALTER TABLE payment.log_users ',
                'REORGANIZE PARTITION p_future INTO (',
                    'PARTITION ', v_partition_name,
                    ' VALUES LESS THAN (''',
                    DATE_FORMAT(DATE_ADD(v_date, INTERVAL 1 DAY), '%Y-%m-%d'),
                    '''),',
                    'PARTITION p_future VALUES LESS THAN (MAXVALUE)',
                ')'
            );

            PREPARE stmt FROM @sql;
            EXECUTE stmt;
            DEALLOCATE PREPARE stmt;

        END IF;

        SET v_date = DATE_ADD(v_date, INTERVAL 1 DAY);

    END WHILE;

END $$

DELIMITER ;


--EVENT: ежедневная ротация партиций логов
CREATE EVENT IF NOT EXISTS payment.ev_rotate_log_partitions
ON SCHEDULE EVERY 1 DAY
 /*
 ============================================================
 Первый запуск: завтра в 02:00
 CURRENT_DATE + 1 день → 00:00 следующего дня
 + 2 часа → 02:00
 ============================================================
 */
STARTS (CURRENT_DATE + INTERVAL 1 DAY) + INTERVAL 2 HOUR
DO
CALL payment.sp_rotate_log_partitions();
