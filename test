--Операция зачисления/списания
DELIMITER $$

CREATE PROCEDURE payment.sp_user_operation (
    IN p_id_user INT UNSIGNED,              -- ID пользователя
    IN p_amount DECIMAL(19,2),              -- Сумма операции в валюте пользователя
    IN p_id_type_oper SMALLINT UNSIGNED     -- ID типа операции
)
BEGIN
    DECLARE v_direction TINYINT;
    DECLARE v_balance_before DECIMAL(19,2);  -- Баланс до выполнения операции
    DECLARE v_balance_after DECIMAL(19,2);   -- Баланс после выполнения операции

    -- Обработчик ошибок: при любой SQL-ошибке откатываем транзакцию
    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
        ROLLBACK;
        RESIGNAL;
    END;

    -- Проверка корректности суммы
    IF p_amount IS NULL OR p_amount <= 0 THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Сумма операции должна быть больше 0';
    END IF;

    START TRANSACTION;

    -- Получаем направление операции из справочника типов операций
    SELECT direction
      INTO v_direction
      FROM payment.type_opers
     WHERE id_type_oper = p_id_type_oper;

    -- Проверяем, что тип операции существует
    IF v_direction IS NULL THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Некорректный тип операции';
    END IF;

    -- Блокируем строку пользователя
    SELECT user_balance
      INTO v_balance_before
      FROM payment.users
     WHERE id_user = p_id_user
     FOR UPDATE;

    -- Проверяем, что пользователь существует
    IF v_balance_before IS NULL THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Пользователь не найден';
    END IF;

    -- Если операция списания, проверяем достаточность средств
    IF v_direction = -1 AND v_balance_before < p_amount THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Недостаточно средств';
    END IF;

    -- Рассчитываем новый баланс
    SET v_balance_after = v_balance_before + (p_amount * v_direction);

    -- Обновляем баланс пользователя
    UPDATE payment.users
       SET user_balance = v_balance_after
     WHERE id_user = p_id_user;

    -- Запись операции
    INSERT INTO payment.user_operations
        (dt, id_user, id_type_oper, direction, amount_oper)
    VALUES
        (UTC_TIMESTAMP(), p_id_user, p_id_type_oper, v_direction, p_amount);

    -- Записываем лог действия пользователя
    INSERT INTO payment.log_users
        (dt, idUser, idAction, Params)
    VALUES
        (
            UTC_TIMESTAMP(),
            p_id_user,
            IF(v_direction = 1, 1, 2),  -- 1 = пополнение, 2 = списание
            JSON_OBJECT(
                'amount', p_amount,
                'type_oper', p_id_type_oper,
                'direction', v_direction,
                'balance_before', v_balance_before,
                'balance_after', v_balance_after
            )
        );
    COMMIT;

    -- Возвращаем результат выполнения
    SELECT
        'Успех' AS status,
        v_balance_before AS balance_before,
        v_balance_after  AS balance_after;

END $$

DELIMITER ;

