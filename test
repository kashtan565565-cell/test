--Таблица дневной консолидации, для хранения агрегатов
CREATE TABLE payment.daily_financial_agg (
    agg_date DATE NOT NULL,
    id_country SMALLINT UNSIGNED NOT NULL,
    id_type_oper SMALLINT UNSIGNED NOT NULL,
    amount_rub DECIMAL(19,2) NOT NULL,
    amount_commission_rub DECIMAL(19,2) NOT NULL,
    amount_no_commission_rub DECIMAL(19,2) NOT NULL,
    cnt_operations BIGINT UNSIGNED NOT NULL,
    PRIMARY KEY (agg_date, id_country, id_type_oper)
) ENGINE=InnoDB;

--Процедура агрегации данных
DELIMITER $$

CREATE PROCEDURE payment.sp_aggregate(IN p_date DATE)
BEGIN

    DECLARE v_last_date DATE;
    DECLARE v_target_date DATE;
    DECLARE v_current_date DATE;

    /*
    ============================================================
    ОПРЕДЕЛЯЕМ РЕЖИМ РАБОТЫ
    - Если передана дата то ручной режим
    - Если NULL то режим EVENT (самовосстановление)
    ============================================================
    */

    IF p_date IS NOT NULL THEN
        SET v_current_date = p_date;
        SET v_target_date  = p_date;

    ELSE
        -- Берём последнюю агрегированную дату
        SELECT MAX(agg_date)
          INTO v_last_date
          FROM payment.daily_financial_agg;

        -- Если агрегатов нет — стартуем с минимальной даты операций
        IF v_last_date IS NULL THEN
            SELECT DATE_SUB(DATE(MIN(dt)), INTERVAL 1 DAY)
              INTO v_last_date
              FROM payment.user_operations;
        END IF;

        -- Следующий день после последней агрегированной даты
        SET v_current_date = DATE_ADD(v_last_date, INTERVAL 1 DAY);

        -- Агрегируем до вчерашнего дня включительно
        SET v_target_date  = CURRENT_DATE - INTERVAL 1 DAY;
    END IF;

    /*
    ============================================================
    ЦИКЛ ПО ДНЯМ
    Обрабатываем все пропущенные дни
    ============================================================
    */

    WHILE v_current_date IS NOT NULL
          AND v_current_date <= v_target_date DO

        /*
        ========================================================
        АГРЕГАЦИЯ ЗА ОДИН ДЕНЬ
        ========================================================
        */

        INSERT INTO payment.daily_financial_agg (
            agg_date,
            id_country,
            id_type_oper,
            amount_rub,
            amount_commission_rub,
            amount_no_commission_rub,
            cnt_operations
        )
        SELECT
            v_current_date,
            u.id_country,
            uo.id_type_oper,

            ROUND(SUM(uo.amount_oper / cur.base_rate),2),

            ROUND(SUM((uo.amount_oper / cur.base_rate) * t.commission / 100),2),

            ROUND(
                SUM(uo.amount_oper / cur.base_rate)
                - SUM((uo.amount_oper / cur.base_rate) * t.commission / 100)
            ,2),

            COUNT(*)

        FROM payment.user_operations uo
        JOIN payment.users u ON u.id_user = uo.id_user
        JOIN payment.type_opers t ON t.id_type_oper = uo.id_type_oper
        JOIN payment.currencies cur ON cur.id_currency = u.id_currency

        WHERE uo.dt >= v_current_date
          AND uo.dt < DATE_ADD(v_current_date, INTERVAL 1 DAY)

        GROUP BY u.id_country, uo.id_type_oper

        /*
        ========================================================
        ИДЕМПОТЕНТНОСТЬ:
        Если запись за день уже есть — обновляем её.
        Это безопасный перезапуск процедуры.
        ========================================================
        */
        ON DUPLICATE KEY UPDATE
            amount_rub = VALUES(amount_rub),
            amount_commission_rub = VALUES(amount_commission_rub),
            amount_no_commission_rub = VALUES(amount_no_commission_rub),
            cnt_operations = VALUES(cnt_operations);

        SET v_current_date = DATE_ADD(v_current_date, INTERVAL 1 DAY);

    END WHILE;

END$$
DELIMITER ;

--EVENT: ежедневная агрегация финансовых данных
CREATE EVENT payment.ev_daily_aggregation
ON SCHEDULE EVERY 1 DAY
 /* 
 ============================================================
 Время первого запуска:
 CURRENT_DATE + 1 день = завтрашняя дата (00:00)
 + 3 часа = 03:00
 Таким образом, агрегируем предыдущий день,
 когда он уже полностью завершён.
 ============================================================
 */
STARTS TIMESTAMP(CURRENT_DATE + INTERVAL 1 DAY) + INTERVAL 3 HOUR
DO
CALL payment.sp_aggregate(NULL);

