CREATE PROCEDURE payment.sp_report_period(
    IN p_from DATETIME,   -- начало периода (UTC)
    IN p_to   DATETIME    -- конец периода (UTC)
)
BEGIN

    DECLARE v_start_day DATE;  -- дата начала (без времени)
    DECLARE v_end_day   DATE;  -- дата конца (без времени)

    --Валидация
    IF p_from IS NULL OR p_to IS NULL OR p_from >= p_to THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Недопустимый диапазон дат';
    END IF;

    SET v_start_day = DATE(p_from);
    SET v_end_day   = DATE(p_to);

    /*
    ============================================================
    ЕСЛИ ПЕРИОД ВНУТРИ ОДНОГО ДНЯ
    Использовать агрегаты нельзя — день неполный.
    Считаем только из сырых данных.
    ============================================================
    */
    IF v_start_day = v_end_day THEN

        SELECT
            CASE WHEN GROUPING(c.name_country)=1 THEN 'TOTAL:' ELSE c.name_country END AS country_name,
            CASE WHEN GROUPING(t.name_oper)=1 THEN 'TOTAL:' ELSE t.name_oper END AS oper_name,

            -- Конвертация в рубли
            ROUND(SUM(uo.amount_oper / cur.base_rate),2) AS amount,

            -- Комиссия
            ROUND(SUM((uo.amount_oper / cur.base_rate) * t.commission / 100),2) AS amount_comiss,

            -- Без комиссии
            ROUND(
                SUM(uo.amount_oper / cur.base_rate)
                - SUM((uo.amount_oper / cur.base_rate) * t.commission / 100)
            ,2) AS amount_no_comiss

        FROM payment.user_operations uo
        JOIN payment.users u ON u.id_user = uo.id_user
        JOIN payment.type_opers t ON t.id_type_oper = uo.id_type_oper
        JOIN payment.currencies cur ON cur.id_currency = u.id_currency
        JOIN payment.countries c ON c.id_country = u.id_country

        WHERE uo.dt >= p_from
          AND uo.dt < p_to

        GROUP BY c.name_country, t.name_oper WITH ROLLUP;

    ELSE

        /*
        ============================================================
        ПЕРИОД БОЛЬШЕ ОДНОГО ДНЯ
        Используем гибридную стратегию:

        - начальный хвост  из user_operations
        - полные дни из агрегаты
        - конечный хвост из  user_operations
        ============================================================
        */

        SELECT
            CASE WHEN GROUPING(c.name_country)=1 THEN 'TOTAL:' ELSE c.name_country END AS country_name,
            CASE WHEN GROUPING(t.name_oper)=1 THEN 'TOTAL:' ELSE t.name_oper END AS oper_name,

            ROUND(SUM(x.amount_rub),2) AS amount,
            ROUND(SUM(x.amount_commission_rub),2) AS amount_comiss,
            ROUND(SUM(x.amount_no_commission_rub),2) AS amount_no_comiss

        FROM
        (

            /*
            --------------------------------------------------------
            НАЧАЛЬНЫЙ ХВОСТ
            От p_from до конца первого дня
            --------------------------------------------------------
            */
            SELECT
                u.id_country,
                uo.id_type_oper,
                SUM(uo.amount_oper / cur.base_rate) AS amount_rub,
                SUM((uo.amount_oper / cur.base_rate) * t.commission / 100) AS amount_commission_rub,
                SUM(uo.amount_oper / cur.base_rate)
                  - SUM((uo.amount_oper / cur.base_rate) * t.commission / 100)
                  AS amount_no_commission_rub
            FROM payment.user_operations uo
            JOIN payment.users u ON u.id_user = uo.id_user
            JOIN payment.type_opers t ON t.id_type_oper = uo.id_type_oper
            JOIN payment.currencies cur ON cur.id_currency = u.id_currency
            WHERE uo.dt >= p_from
              AND uo.dt < DATE_ADD(v_start_day, INTERVAL 1 DAY)
            GROUP BY u.id_country, uo.id_type_oper

            UNION ALL

            /*
            --------------------------------------------------------
            ПОЛНЫЕ ДНИ
            Берём из таблицы консолидации
            --------------------------------------------------------
            */
            SELECT
                id_country,
                id_type_oper,
                amount_rub,
                amount_commission_rub,
                amount_no_commission_rub
            FROM payment.daily_financial_agg
            WHERE agg_date > v_start_day
              AND agg_date < v_end_day

            UNION ALL

            /*
            --------------------------------------------------------
            КОНЕЧНЫЙ ХВОСТ
            От начала последнего дня до p_to
            --------------------------------------------------------
            */
            SELECT
                u.id_country,
                uo.id_type_oper,
                SUM(uo.amount_oper / cur.base_rate),
                SUM((uo.amount_oper / cur.base_rate) * t.commission / 100),
                SUM(uo.amount_oper / cur.base_rate)
                  - SUM((uo.amount_oper / cur.base_rate) * t.commission / 100)
            FROM payment.user_operations uo
            JOIN payment.users u ON u.id_user = uo.id_user
            JOIN payment.type_opers t ON t.id_type_oper = uo.id_type_oper
            JOIN payment.currencies cur ON cur.id_currency = u.id_currency
            WHERE uo.dt >= v_end_day
              AND uo.dt < p_to
            GROUP BY u.id_country, uo.id_type_oper

        ) x

        JOIN payment.countries c ON c.id_country = x.id_country
        JOIN payment.type_opers t ON t.id_type_oper = x.id_type_oper

        GROUP BY c.name_country, t.name_oper WITH ROLLUP;

    END IF;

END $$

