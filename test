DELIMITER $$

CREATE PROCEDURE payment.sp_user_report(
    IN p_user_id INT,
    IN p_from DATETIME,
    IN p_to   DATETIME,
    IN p_currency_id INT   -- NULL = RUB
)
BEGIN

    DECLARE v_target_rate DECIMAL(18,8);
    DECLARE v_exists INT;


    --ВАЛИДАЦИЯ ПАРАМЕТРОВ
    IF p_user_id IS NULL 
       OR p_from IS NULL 
       OR p_to IS NULL 
       OR p_from >= p_to THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Некорректные входные параметры';
    END IF;

    /*
    ============================================================
    ОПРЕДЕЛЕНИЕ ЦЕЛЕВОЙ ВАЛЮТЫ
    По умолчанию — RUB (base_rate = 1)
    ============================================================
    */
    IF p_currency_id IS NULL THEN
        SET v_target_rate = 1;
    ELSE

        -- Проверяем существование валюты
        SELECT COUNT(*)
        INTO v_exists
        FROM payment.currencies
        WHERE id_currency = p_currency_id;

        IF v_exists = 0 THEN
            SIGNAL SQLSTATE '45000'
            SET MESSAGE_TEXT = 'Валюта не найдена';
        END IF;

        -- Получаем курс целевой валюты
        SELECT base_rate
        INTO v_target_rate
        FROM payment.currencies
        WHERE id_currency = p_currency_id;

    END IF;

    /*
    ============================================================
    ЛОГИКА КОНВЕРТАЦИИ
    Формула:
        RUB = amount / base_rate
        target = RUB * v_target_rate
    ============================================================
    */

    SELECT
        CASE 
            WHEN GROUPING(t.name_oper)=1 THEN 'TOTAL:' 
            ELSE t.name_oper 
        END AS oper_name,

        ROUND(SUM(base_amount),2) AS amount,

        ROUND(SUM(base_amount * t.commission / 100),2) 
            AS amount_commission,

        ROUND(
            SUM(base_amount - base_amount * t.commission / 100)
        ,2) AS amount_no_commission

    FROM
    (
        SELECT
            uo.id_type_oper,

            -- Переводим в RUB, затем в целевую валюту
            (uo.amount_oper / cur.base_rate) * v_target_rate AS base_amount

        FROM payment.user_operations uo
        JOIN payment.users u ON u.id_user = uo.id_user
        JOIN payment.currencies cur ON cur.id_currency = u.id_currency

        WHERE uo.id_user = p_user_id
          AND uo.dt >= p_from
          AND uo.dt <  p_to

    ) x

    JOIN payment.type_opers t 
        ON t.id_type_oper = x.id_type_oper

    GROUP BY t.name_oper WITH ROLLUP;

END $$

DELIMITER ;

